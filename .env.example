# Hearth configuration — copy to .env and fill in. The .env file is
# gitignored; NEVER commit real values. Exported environment variables
# always override this file.

# Google Calendar OAuth client (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID, type "Web application"). Redirect URI must
# be: ${HEARTH_BASE_URL}/api/widgets/calendar/google/callback
HEARTH_GOOGLE_CLIENT_ID=
HEARTH_GOOGLE_CLIENT_SECRET=

# Where Hearth is reachable from the browser doing the Google consent flow.
# Defaults to http://localhost:8080 when unset.
# HEARTH_BASE_URL=http://localhost:8080

# Extra hostnames Hearth will accept in the Host header, comma-separated.
# Only needed behind a reverse proxy that presents a public name, e.g. a
# Tailscale/nginx host. localhost, private LAN IPs, and *.local always work.
# HEARTH_ALLOWED_HOSTS=hearth.example.com
